# Tumblr OAuth Credentials
# Get these from: https://www.tumblr.com/oauth/apps → Explore API → Allow → Show keys
TUMBLR_CONSUMER_KEY=your_consumer_key_here
TUMBLR_CONSUMER_SECRET=your_consumer_secret_here
TUMBLR_TOKEN=your_oauth_token_here
TUMBLR_TOKEN_SECRET=your_oauth_token_secret_here

# Optional: default blog to post to (without .tumblr.com)
TUMBLR_DEFAULT_BLOG=
